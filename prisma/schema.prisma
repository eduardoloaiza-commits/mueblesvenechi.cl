generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Cotizante capturado por el configurador (cocinas y closets).
// La captura es progresiva: el Lead se crea al ingresar los datos de contacto
// y guarda un snapshot de la configuración cotizada.
model Lead {
  id     String @id @default(cuid())
  name   String
  phone  String
  email  String?
  comuna String?

  product     String  @default("cocina") // "cocina" | "closet"
  projectType String? // "nueva" | "remodelacion"
  timeframe   String?

  // Snapshot de la configuración cotizada.
  // Cocina: layout/baseMeters/wallMeters/countertop.
  // Closet: closetType/doorType/heightOption; baseMeters = metros de frente.
  // front y extras son compartidos por ambos productos.
  layout       String?
  baseMeters   Float?
  drawerMeters Float? // metros de base con cajonera (cocina)
  wallMeters   Float?
  wallPosition String? // "izquierda" | "centro" | "derecha"
  countertop   String?
  closetType   String?
  doorType     String?
  heightOption String?
  front        String?
  lacquerColor String? // color cuando front = "laqueado" (cocina y closet)
  extras       String[] @default([])
  priceFrom    Int?
  priceTo      Int?

  source         String  @default("configurador")
  kommoLeadId    Int?
  kommoContactId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}
